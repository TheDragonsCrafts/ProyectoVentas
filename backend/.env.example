# PostgreSQL Connection URL
# Replace USER, PASSWORD, HOST, PORT, DATABASE_NAME with your actual credentials/info
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE_NAME?schema=public"

# JWT Secret Key for signing tokens
# Choose a long, random, and strong string for production
JWT_SECRET="your_super_secret_jwt_key_here_please_change_me"

# Port for the backend server
PORT=3000

# Optional: Direct Database Connection Parameters
# Uncomment and use these if you prefer not to use the DATABASE_URL string
# Note: If DATABASE_URL is set, these might be ignored by the current db/connection.ts setup
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_NAME=your_db_name
